# Private/local production example.
# Copy this file to .env.production and replace the placeholder values.

DB_NAME=catworld
DB_USER=catworld_app
DB_PASSWORD=replace_with_a_strong_password
DB_ROOT_PASSWORD=replace_with_a_strong_root_password

# Bootstraps the first ADMIN only when the users table is empty.
CATWORLD_SECURITY_USERNAME=admin
CATWORLD_SECURITY_PASSWORD=replace_with_a_strong_admin_password
CATWORLD_SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:4200

# Frontend port exposed on the host machine.
FRONTEND_PORT=4200
