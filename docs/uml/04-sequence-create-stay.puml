@startuml
actor Client as client
participant "StayController" as controller
participant "StayService" as service
participant "StayMapper" as mapper
participant "CatRepository" as catRepo
participant "StayRepository" as stayRepo

client -> controller: POST /api/stays (catIds, startAt, endAt, notes)
controller -> controller: Bean Validation (@Valid)

alt invalid request body
  controller --> client: 400
else valid request body
  controller -> service: createStay(stayRequestDTO)
  service -> service: validate(endAt > startAt)

  alt endAt is not after startAt
    service --> controller: BadRequestException
    controller --> client: 400
  else dates are valid
    service -> mapper: toEntity(stayRequestDTO)
    mapper --> service: Stay

    loop each catId in request catIds
      service -> catRepo: findById(catId)
      catRepo --> service: Optional<Cat>

      alt cat missing
        service --> controller: ResourceNotFoundException
        controller --> client: 404
      else cat found
        service -> service: set or validate owner
        service -> service: scan cat.stayCats for active date overlap

        alt overlap found
          service --> controller: ConflictException
          controller --> client: 409
        else no overlap
          service -> service: build StayCat link for stay and cat
        end
      end
    end

    service -> service: set stay owner and stayCats
    service -> stayRepo: save(stay)
    note right of stayRepo
      Stay.stayCats uses cascade ALL,
      so saving Stay persists stay_cat rows.
    end note
    stayRepo --> service: saved Stay
    service -> mapper: toResponseDTO(saved Stay)
    mapper --> service: StayResponseDTO
    service --> controller: StayResponseDTO
    controller --> client: 201 Created
  end
end

@enduml
