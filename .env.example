# Local Docker Compose defaults. Replace these values in your own .env file.
DB_NAME=catworld
DB_USER=catworld
DB_PASSWORD=change_me_local_password
DB_ROOT_PASSWORD=change_me_local_root_password
DB_PORT=3306

# Bootstraps the first ADMIN only when the users table is empty.
CATWORLD_SECURITY_USERNAME=admin
CATWORLD_SECURITY_PASSWORD=change_me_local_admin_password
CATWORLD_SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:4200

# API port exposed by Docker Compose
APP_PORT=8080

# Useful when running the API locally outside Docker
DB_HOST=localhost
